# Patterns to ignore when building packages.
# This supports shell glob matching, relative path matching, and
# negation (prefixed with !). Only one pattern per line.
.DS_Store

# Common VCS dirs
.git/
.gitignore
.bzr/
.bzrignore
.hg/
.hgignore
.svn/

# Common backup files
*.swp
*.bak
*.tmp
*.orig
*~

# Various IDEs
.project
.idea/
*.tmproj
.vscode/

# OS cruft
.DS_Store
Thumbs.db
__pycache__/

# Keep README.md (referenced from the chart), exclude everything else *.md
# Cannot exclude *.md broadly because README.md must ship with the chart;
# .helmignore patterns are not negatable per-file in a portable way, so we
# explicitly call out the docs we don't want shipped with the chart.
NOTES-DRAFT.md
