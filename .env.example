# Postgres connection string used by the API and migrations.
DATABASE_URL=postgres://nutrition:nutrition@localhost:5432/nutrition?sslmode=disable

# Two static bearer tokens. Must each be at least 16 bytes and differ from each other.
# Generate fresh values with: openssl rand -hex 32
MOBILE_API_TOKEN=replace-me-with-a-long-random-string
AGENT_API_TOKEN=replace-me-with-a-different-long-random-string

# IANA timezone used when summary endpoints are called without an explicit tz query param.
DEFAULT_USER_TZ=Europe/Berlin

# Timeout for individual Open Food Facts HTTP calls, in seconds.
OFF_TIMEOUT_SECONDS=5

# Contact value baked into the OFF client's User-Agent header.
OFF_USER_AGENT_CONTACT=+https://github.com/vinzenzs/kazper

# How long idempotency records are retained before cleanup, in hours.
IDEMPOTENCY_TTL_HOURS=24

# Run schema migrations on application startup. Set to false in production deploys
# where migrations are managed out-of-band.
MIGRATE_ON_START=true

# HTTP listen address.
HTTP_ADDR=:8080

# Mount the Swagger UI at /swagger/* when running in release mode. Always
# available in debug mode (e.g. `go run`) regardless of this value.
SWAGGER_ENABLED=false

# ---- MCP server (cmd/mcp) ----

# Where the REST API lives, as seen by the MCP server.
NUTRITION_API_URL=http://localhost:8080

# Per-tool HTTP timeout for calls the MCP server makes to the REST API, in seconds.
MCP_REQUEST_TIMEOUT_SECONDS=10

# ---- Vision (Claude) — used only by POST /meals/from_photo ----

# Anthropic API key for the Claude Vision endpoint that parses meal photos
# into freeform meals. When unset, /meals/from_photo returns
# 503 vision_unavailable; everything else runs unchanged. Get one at
# https://console.anthropic.com/.
# ANTHROPIC_API_KEY=sk-ant-api03-...

# Which Claude model to use for vision parsing. Default is the current
# generation Sonnet. Swap to a faster variant (e.g. claude-haiku-4-5) if
# latency matters more than accuracy.
CLAUDE_VISION_MODEL=claude-sonnet-4-6

# Per-call timeout for the Anthropic Messages call, in seconds.
VISION_TIMEOUT_SECONDS=15

# Hard ceiling on the multipart image upload size, in bytes. 10MB by default.
# Larger images are rejected with 413 image_too_large.
MEAL_FROM_PHOTO_MAX_BYTES=10485760

# ---- Garmin integration (opt-in) ----

# Dedicated bearer token the garmin-bridge authenticates with (client_id="garmin").
# When unset, the /garmin/token endpoints return 503 garmin_disabled and the rest
# of the API runs unchanged. Generate with: openssl rand -hex 32
# GARMIN_API_TOKEN=replace-me-with-a-long-random-string

# Base64-encoded AES-256 key used to encrypt the stored Garmin token blob at rest.
# Required only when GARMIN_API_TOKEN is set; must decode to exactly 32 bytes.
# Generate with: openssl rand -base64 32
# GARMIN_TOKEN_ENC_KEY=replace-me-with-a-base64-32-byte-key

# In-cluster base URL of the garmin-bridge. When set, /garmin/login and
# /garmin/login/mfa proxy to it; when empty those endpoints return 503
# garmin_disabled. Optional and independent of GARMIN_API_TOKEN.
# GARMIN_BRIDGE_URL=http://garmin-bridge:8090
