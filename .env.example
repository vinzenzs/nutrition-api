# Postgres connection string used by the API and migrations.
DATABASE_URL=postgres://nutrition:nutrition@localhost:5432/nutrition?sslmode=disable

# Two static bearer tokens. Must each be at least 16 bytes and differ from each other.
# Generate fresh values with: openssl rand -hex 32
MOBILE_API_TOKEN=replace-me-with-a-long-random-string
AGENT_API_TOKEN=replace-me-with-a-different-long-random-string

# IANA timezone used when summary endpoints are called without an explicit tz query param.
DEFAULT_USER_TZ=Europe/Berlin

# Timeout for individual Open Food Facts HTTP calls, in seconds.
OFF_TIMEOUT_SECONDS=5

# Contact value baked into the OFF client's User-Agent header.
OFF_USER_AGENT_CONTACT=+https://github.com/vinzenzs/nutrition-api

# How long idempotency records are retained before cleanup, in hours.
IDEMPOTENCY_TTL_HOURS=24

# Run schema migrations on application startup. Set to false in production deploys
# where migrations are managed out-of-band.
MIGRATE_ON_START=true

# HTTP listen address.
HTTP_ADDR=:8080

# Mount the Swagger UI at /swagger/* when running in release mode. Always
# available in debug mode (e.g. `go run`) regardless of this value.
SWAGGER_ENABLED=false

# ---- MCP server (cmd/mcp) ----

# Where the REST API lives, as seen by the MCP server.
NUTRITION_API_URL=http://localhost:8080

# Per-tool HTTP timeout for calls the MCP server makes to the REST API, in seconds.
MCP_REQUEST_TIMEOUT_SECONDS=10
